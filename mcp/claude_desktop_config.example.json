{
  "mcpServers": {
    "trilium-presenter": {
      "command": "/path/to/trilium-mcp/.venv/bin/python",
      "args": ["/path/to/trilium-mcp/server.py"],
      "env": {
        "TRILIUM_URL": "http://localhost:9160",
        "TRILIUM_API_KEY": "",
        "TRILIUM_DEFAULT_PARENT": "root"
      }
    }
  }
}
